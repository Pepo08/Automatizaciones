      "id": "n-config",
      "name": "Config"
    },
    {
      "parameters": {
        "jsCode": "// Code node: Aplanar participantes + deduplicar por email + acumular tags\nconst items = $input.all();\n\n// La data viene como un array de remates dentro de body\nconst remates = items[0].json.body || items[0].json;\n\n// Map para deduplicar por email\nconst contactosPorEmail = new Map();\n\nfor (const remate of remates) {\n  const idRemate = remate.idRemate;\n  const tagsRemate = remate.tags || [];\n  \n  // Combinamos los tags del remate + el idRemate como tag\n  const tagsConId = [...tagsRemate, `remate-${idRemate}`];\n  \n  for (const participante of remate.participantes || []) {\n    const email = (participante.direccionCorreo || '').toLowerCase().trim();\n    \n    // Saltear emails vacíos o inválidos\n    if (!email || !email.includes('@')) continue;\n    \n    if (contactosPorEmail.has(email)) {\n      // Ya existe: acumular tags sin duplicar\n      const existente = contactosPorEmail.get(email);\n      for (const tag of tagsConId) {\n        if (!existente.tags.includes(tag)) {\n          existente.tags.push(tag);\n        }\n      }\n    } else {\n      // Nuevo: crear entrada\n      contactosPorEmail.set(email, {\n        email: email,\n        alias: participante.alias || '',\n        tags: [...tagsConId]\n      });\n    }\n  }\n}\n\n// Convertir el Map a array de items para n8n\nconst resultado = Array.from(contactosPorEmail.values()).map(contacto => ({\n  json: {\n    email: contacto.email,\n    alias: contacto.alias,\n    tags: contacto.tags\n  }\n}));\n\nreturn resultado;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,

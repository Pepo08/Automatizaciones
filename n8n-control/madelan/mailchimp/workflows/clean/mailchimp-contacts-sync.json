      "id": "45a6d3cf-f215-4e21-b569-5dd3a993f1ab",
      "name": "Aggregate"
    },
    {
      "parameters": {
        "jsCode": "// Code node: Reconciliación source (REST) vs destino (Mailchimp)\n// Outputs: create | update | update_tags | skip\n\nconst aggregateData = $(\"Aggregate\").first().json.data || [];\nconst mailchimpItems = $(\"Get many members\").all();\n\n// Map de Mailchimp por email\nconst membersByEmail = new Map();\nfor (const item of mailchimpItems) {\n  const m = item.json;\n  const email = (m.email_address || '').toLowerCase().trim();\n  if (email) {\n    membersByEmail.set(email, {\n      status: m.status,\n      tags: (m.tags || []).map(t => t.name || t),\n      merge_fields: m.merge_fields || {},\n      full_name: m.full_name || ''\n    });\n  }\n}\n\n// Reconciliar\nconst output = [];\n\nfor (const contacto of aggregateData) {\n  const email = (contacto.email || '').toLowerCase().trim();\n  if (!email) continue;\n\n  const sourceTags = contacto.tags || [];\n  const alias = contacto.alias || '';\n\n  const found = membersByEmail.get(email);\n\n  if (!found) {\n    // No existe → crear\n    output.push({\n      json: {\n        action: 'create',\n        email,\n        alias,\n        tags: sourceTags\n      }\n    });\n  } else {\n    // Ya existe → verificar qué cambió\n    const tagsActuales = found.tags;\n    const tagsNuevos = sourceTags.filter(t => !tagsActuales.includes(t));\n\n    // Comparar alias con lo que hay en Mailchimp\n    const aliasActual = (found.full_name || '').trim();\n    const aliasCambio = alias && alias !== aliasActual;\n\n    if (aliasCambio && tagsNuevos.length > 0) {\n      // Cambió alias Y tiene tags nuevos → update (hace ambas cosas)\n      output.push({\n        json: {\n          action: 'update',\n          email,\n          alias,\n          tags_agregar: tagsNuevos,\n          tags_actuales: tagsActuales,\n          tags_final: [...tagsActuales, ...tagsNuevos]\n        }\n      });\n    } else if (aliasCambio) {\n      // Solo cambió alias → update\n      output.push({\n        json: {\n          action: 'update',\n          email,\n          alias,\n          tags_actuales: tagsActuales\n        }\n      });\n    } else if (tagsNuevos.length > 0) {\n      // Solo tags nuevos → update_tags\n      output.push({\n        json: {\n          action: 'update_tags',\n          email,\n          alias,\n          tags_agregar: tagsNuevos,\n          tags_actuales: tagsActuales,\n          tags_final: [...tagsActuales, ...tagsNuevos]\n        }\n      });\n    } else {\n      // Sin cambios → skip\n      output.push({\n        json: {\n          action: 'skip',\n          email,\n          alias\n        }\n      });\n    }\n  }\n}\n\n// Resumen\nconst resumen = {\n  total: output.length,\n  crear: output.filter(i => i.json.action === 'create').length,\n  update: output.filter(i => i.json.action === 'update').length,\n  update_tags: output.filter(i => i.json.action === 'update_tags').length,\n  skip: output.filter(i => i.json.action === 'skip').length\n};\n\nconsole.log('Reconciliación:', JSON.stringify(resumen));\n\nreturn output;"
      },
